[
  {
    "name": "Create Deck flow",
    "steps": [
      {
        "send": { "callback": "deck:create" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What should we call this deck?" } }
        ]
      },
      {
        "send": { "text": "Spanish" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Name: \"Spanish\"\n\nCreate this deck?" } }
        ]
      },
      {
        "send": { "callback": "deck:create:confirm:Spanish" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "\"Spanish\" is ready! Tap \"Add Card\" to put some words in it." } }
        ]
      }
    ]
  }
]
